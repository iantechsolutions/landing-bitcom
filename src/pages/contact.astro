---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
    <header class="header">
        <div class="logo-container">
            <figure>
                <a href="/" class="link"><img class="logo" src="images/logo bitcom.png" alt="" /></a>
            </figure>
        </div>
        <div class="menu">
    <img class="abrir-menu" id="abrir" src="./images/cerrar menu.png" />
        <nav class="nav" id="nav">
      <img class="cerrar-menu" id="cerrar" src="./images/cerrar menu.png" />
        <div class="navlinks">
      <ul>
        <li>
          <a href="#home-4" class="plat">Nuestra Plataforma</a>
        </li>
        <li>
          <a href="#home-3">Servicios</a>
        </li>
        <li>
            <figure>
          <a href="https://bitcompay.vercel.app/dashboard"><img src="/images/btnacc.png" class="btn-acceso" alt="" /></a>
        </figure>
        </li>
      </ul>
    </div>
    </nav>
      </div>
    </header>
    
    

    <section class="contacto">
        <div class="contact-container">
            <h1>Contactanos</h1>
            <p>Dejanos tu mensaje y consultanos tus dudas!</p>
            <form>
                <label for="name">Nombre y apellido*</label>
                <input type="text" id="name" name="name" required>

                <label for="cuil">CUIL/CUIT*</label>
                <input type="text" id="cuil" name="cuil" required>

                <label for="email">Mail*</label>
                <input type="email" id="email" name="email" required>

                <label for="company">Empresa*</label>
                <input type="text" id="company" name="company" required>

                <label for="message">Mensaje*</label>
                <textarea id="message" name="message" required></textarea>
            </form>
        </div>
    </section>


<script>
  const nav = document.querySelector("#nav");
  const abrir = document.querySelector("#abrir");
  const cerrar = document.querySelector("#cerrar");

  abrir.addEventListener("click", () => {
    nav.classList.add("visible");
  });

  cerrar.addEventListener("click", () => {
    nav.classList.remove("visible");
  });
</script>

    <style>
        body {
    background-image: url("images/1440.png");
    background-size: cover;
}

.header {
    height: auto;
    display: grid;
    grid-template-columns: repeat(2, 2fr);
    align-items: center;

    background-color: #212121;
}



.logo-container {
    height: 100%;
    background-color: #212121;
    padding-left: 8vw;
}

.logo-container figure {
    border-left: 0.3vh dotted #1bdfb7;
    border-radius: 0 3vh 0;
    padding-top: 3.5vh;
    padding-bottom: 3vh;
    border-bottom: 0.3vh dotted #1bdfb7;
    display: flex;
    align-items: center;
    height: 100%;
}

.logo {
    height: 4vh;
    margin-left: 10dvw;
}

nav {
    padding-top: 3.5vh;
    padding-bottom: 3vh;
    border-bottom: 0.3vh dotted #1bdfb7;
    display: flex; 
    align-items: center;
    height: 100%;
}

.navlinks {

}

.navlinks ul {
    list-style-type: none;
    display: flex;
    gap: 2vw;
    align-items: center;
    text-align: center;
}

.navlinks li {
    font-size: 2.4vh;
}

.navlinks a {
    text-decoration: none;
    color: white;
}

  .btn-acceso {
    height: 4vh;
    width: auto;
  }

 .navlinks a.plat {
    color: #1bdfb7;
  }


.abrir-menu,
  .cerrar-menu {
    height: 3.5vh;
    height: auto;
    display: none;
  }



.contacto {
    display: flex;
    justify-content: center;
    margin-top: 8vh;
}

.contact-container {
    background-color: white;
    padding: 3vw;
    border-radius: 40px;
    text-align: center;
}

h1 {
    color: #1bdfb7;
    font-weight: 500;
    font-size: 2.3vw;
}

p {
    font-size: 1.1vw;
    font-weight: 500;
    color: #666;
    margin-bottom: 2vh;
}

form {
    display: flex;
    flex-direction: column;
    align-items: start;
    border-top: 0.8px solid #666;
}

label {
    width: 25vw;
    margin-top: 10px;
    text-align: left;
    font-size: 0.8vw;
    color: grey;
}

input,
textarea {
    width: 100%;
    padding: 10px;
    background-color: rgb(230, 230, 230);
    margin-top: 1vh;
    border: 0.2px solid #ccc;
    border-radius: 5px;
}

textarea {
    height: 15vh;
}


 @media screen and (max-width: 768px){
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .abrir-menu, .cerrar-menu {
        display: block;
        cursor: pointer;
    }
    .abrir-menu {
        margin-left: 5vh;
    }

    .menu {
        order: 1;
    }

    .logo-container {
        order: 2;
        margin-left: auto;
    }

    .logo {
        margin-left: 0;
        margin-right: 10dvw;
        border: none;
    }

    .logo-container figure {
 
  border-left:  none; 

      border-bottom:  none;
}

.nav {
        opacity: 0;
        visibility: hidden;
        position: absolute;
        top: 0;
        left: 0;
        height: 100vh;
        width: 100vw;
        background-color: #212121;
        padding: 2rem;
        box-shadow: 0 0 0 100vmax rgba(0, 0, 0, .5);
    }

    .nav.visible {
        opacity: 1;
        visibility: visible;
    }

    .navlinks {
        margin-top: 20px;
        border-bottom: 0;
    }

    .navlinks ul{
        display: flex;
        flex-direction: column;
        align-items: start;
        text-align: center;
    }

    .navlinks a {
        color: white;
    }

    
 }

@media screen and (max-width: 430px){
    h1 {
    font-size: 10vw;
}
    p{
        font-size: 3vw;
    }
    label {
    font-size: 2.5vw;
}
}
    </style>


</Layout>